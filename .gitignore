# Claude Code 配置目录 - 白名单模式
# 只有明确列出的文件/目录才会被版本控制

# 忽略所有
*

# ===== 白名单 =====

# 核心配置
!.github/
!.github/**
!.gitignore
!CLAUDE.md
!README.md
!settings.json
!settings.local.example.json
!.mcp.example.json

# 自定义 agents
!agents/
!agents/**

# 自定义 skills (复杂能力，目录结构)
!skills/
!skills/**
skills/**/workspace/
skills/**/*-workspace/

# 自定义 commands (斜杠命令，单文件)
!commands/
!commands/**

# 自定义 hooks (事件钩子脚本)
!hooks/
!hooks/**

# 自定义 rules (始终加载的核心规则)
!rules/
!rules/**

# 按需加载的规则库
!rules-library/
!rules-library/**

# 规则触发索引（由 build-rules-index.py 生成）
!rules-index.json

# 知识沉淀（全局用户级，位于 ~/.claude/notes）
!notes/
!notes/**

# 三层记忆系统（代码片段、模块、系统级记忆）
!memory/
!memory/**

# CC ↔ Codex 共享知识层
!shared-knowledge/
!shared-knowledge/**
shared-knowledge/codex-feedback.jsonl
shared-knowledge/sync.log
# 机器本地产物：含绝对路径和时间戳，跨机同步会互相覆盖
shared-knowledge/sync-manifest.json

# 当前仓库这个项目自己的任务目录（标准形态是 <project>/.claude/tasks/）
# 这里只同步目录说明文档；具体 task 实例默认不入库
!tasks/
!tasks/README.md

# Metrics 周报数据（发布到 GitHub Pages）
# 只放行 weekly JSON 和 dashboard 模板，其他运行时数据（events/daily/reports）不入库
!metrics/
!metrics/weekly/
!metrics/weekly/*.json
!metrics/dashboard/
!metrics/dashboard/weekly.html
!metrics/dashboard/preview.svg
!metrics/i18n/
!metrics/i18n/*.json
!metrics/asset-catalog.yaml
!metrics/asset-descriptions.json
# 显式排除运行时产物
metrics/events/
metrics/daily/
metrics/reports/
metrics/dashboard/weekly-rendered.html

# ===== 显式忽略（已被 * 覆盖，此处为文档说明）=====

# 敏感凭据（绝对不能同步）
# .credentials.json          - OAuth 令牌

# 插件相关（不同步）
# plugins/installed_plugins.json  - 自动生成的安装记录
# plugins/cache/                  - 插件缓存（会无限增长）
# plugins/marketplaces/           - 市场仓库（自动拉取）

# 运行时数据（不同步）
# cache/                     - 缓存数据
# statsig/                   - 统计数据
# tasks/**/.lock             - 任务运行时锁文件
# tasks/**/.highwatermark    - 任务运行时游标
# todos/                     - 旧任务列表
# projects/                  - 项目数据

# 本地覆盖配置（不同步）
# settings.local.json        - 个人/办公环境覆盖
# .mcp.json                  - 项目级 MCP 覆盖
# .codex/config.toml         - 本地生成的 Codex MCP bridge
.codex/config.toml

# ===== 临时文件 =====
__pycache__/
*.pyc
*.pyo
.DS_Store
*.swp
*.swo
*~

# 冷记忆（不同步）
.cold-storage/
skills/pkg-dive-workspace/

# 第三方 skill 只读原件（从 marketplace 缓存复制，由 vendor-sync.sh 管理）
skills/vendor/*/
!skills/vendor/.vendor-manifest.json
