{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bash ~/.claude/rules/technique/rate-limit-management/scripts/*)",
      "Bash(bash ~/.claude/hooks/*)",
      "Bash(bash ~/.claude/hooks/lesson-capture/*)",
      "Bash(bash ~/.claude/hooks/consolidate/*)",
      "Bash(bash ~/.claude/hooks/skill-loader/*)",
      "mcp__pencil"
    ],
    "global": {
      "Agent": "allow",
      "AskUserQuestion": "allow",
      "Bash": "allow",
      "CronCreate": "allow",
      "CronDelete": "allow",
      "CronList": "allow",
      "Edit": "allow",
      "Glob": "allow",
      "Grep": "allow",
      "LSP": "allow",
      "Read": "allow",
      "Skill": "allow",
      "TaskCreate": "allow",
      "TaskGet": "allow",
      "TaskList": "allow",
      "TaskOutput": "allow",
      "TaskUpdate": "allow",
      "WebFetch": "allow",
      "WebSearch": "allow",
      "Write": "allow"
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-maintenance.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id skill-loader -- bash \"$HOME/.claude/hooks/skill-loader/skill-inject.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id scale-gate-write -- bash \"$HOME/.claude/hooks/scale-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id pre-write-gate -- bash \"$HOME/.claude/hooks/pre-write-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id scale-gate-edit -- bash \"$HOME/.claude/hooks/scale-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id pre-edit-gate -- bash \"$HOME/.claude/hooks/pre-edit-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id pre-agent-gate-agent -- bash \"$HOME/.claude/hooks/pre-agent-gate.sh\""
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id pre-agent-gate-task -- bash \"$HOME/.claude/hooks/pre-agent-gate.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id verification-gate --block-on-exit2 -- bash \"$HOME/.claude/hooks/verification-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id lesson-gate --block-on-exit2 -- bash \"$HOME/.claude/hooks/lesson-capture/lesson-gate.sh\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id context-monitor -- bash \"$HOME/.claude/hooks/context-monitor.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-maintenance.py\""
          },
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id session-end-consolidate -- bash \"$HOME/.claude/hooks/consolidate/session-end-consolidate.sh\""
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$HOME/.claude/.claude/hooks/hook-error-wrapper.py\" --hook-id on-rate-limit-stop -- bash \"$HOME/.claude/rules/technique/rate-limit-management/scripts/on-rate-limit-stop.sh\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/rules/technique/rate-limit-management/scripts/statusline-wrapper.sh"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true,
    "codex@openai-codex": true,
    "ttcodex@openai-codex": true
  },
  "extraKnownMarketplaces": {
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "codemossProviderId": "4e65b9d5-0e52-4753-b065-660f9e8e1494",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true
}
