{
  "env": {
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(bash ~/.claude/rules/technique/rate-limit-management/scripts/*)",
      "Bash(bash ~/.claude/hooks/*)",
      "Bash(bash ~/.claude/hooks/lesson-capture/*)",
      "Bash(bash ~/.claude/hooks/consolidate/*)",
      "Bash(bash ~/.claude/hooks/skill-loader/*)",
      "mcp__pencil"
    ],
    "global": {
      "Agent": "allow",
      "AskUserQuestion": "allow",
      "Bash": "allow",
      "CronCreate": "allow",
      "CronDelete": "allow",
      "CronList": "allow",
      "Edit": "allow",
      "Glob": "allow",
      "Grep": "allow",
      "LSP": "allow",
      "Read": "allow",
      "Skill": "allow",
      "TaskCreate": "allow",
      "TaskGet": "allow",
      "TaskList": "allow",
      "TaskOutput": "allow",
      "TaskUpdate": "allow",
      "WebFetch": "allow",
      "WebSearch": "allow",
      "Write": "allow"
    }
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/skill-loader/skill-inject.sh"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write",
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-write-gate.sh"
      },
      {
        "matcher": "Edit",
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-edit-gate.sh"
      },
      {
        "matcher": "Agent",
        "type": "command",
        "command": "bash ~/.claude/hooks/pre-agent-gate.sh"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/verification-gate.sh"
      },
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/lesson-capture/lesson-gate.sh"
      },
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/context-monitor.sh"
      }
    ],
    "SessionEnd": [
      {
        "type": "command",
        "command": "bash ~/.claude/hooks/consolidate/session-end-consolidate.sh"
      }
    ],
    "StopFailure": [
      {
        "type": "command",
        "command": "bash ~/.claude/rules/technique/rate-limit-management/scripts/on-rate-limit-stop.sh"
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/rules/technique/rate-limit-management/scripts/statusline-wrapper.sh"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": true,
    "claude-mem@thedotmack": true,
    "rust-analyzer-lsp@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  },
  "extraKnownMarketplaces": {
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "chrome-devtools-plugins": {
      "source": {
        "source": "github",
        "repo": "ChromeDevTools/chrome-devtools-mcp"
      }
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "codemossProviderId": "4e65b9d5-0e52-4753-b065-660f9e8e1494",
  "autoMemoryEnabled": true
}
