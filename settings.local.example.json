{
  "extraKnownMarketplaces": {
    "ttcodex-local": {
      "source": {
        "source": "path",
        "path": "/Users/yourname/.claude/plugins/marketplaces/ttcodex-local"
      }
    }
  },
  "enabledPlugins": {
    "ttcodex@ttcodex-local": true
  },
  "codemossProviderId": "replace-with-your-provider-id",
  "mcpServers": {
    "semi-mcp": {
      "command": "bunx",
      "args": [
        "-y",
        "--registry=http://bnpm.byted.org/",
        "@ies/semi-mcp-bytedance"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/"
      }
    },
    "playwright": {
      "command": "bunx",
      "args": [
        "--registry=http://bnpm.byted.org/",
        "@playwright/mcp"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/"
      }
    },
    "feishu": {
      "command": "npx",
      "args": [
        "@i18n-ecom/feishu-lark-mcp-server",
        "--registry=https://bnpm.byted.org/"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/",
        "FEISHU_ENABLED_TOOLS": "feishu_create_doc,feishu_fetch_doc,feishu_update_doc,feishu_search"
      }
    },
    "lark-docs": {
      "command": "bunx",
      "args": [
        "--registry=http://bnpm.byted.org/",
        "@byted/mcp-lark-docs-ext"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/",
        "AUTH_CALLBACK_PORT": "6688",
        "AUTH_CALLBACK_ENDPOINT": "/lark/callback",
        "LARK_TENANT": "bytedance"
      }
    },
    "tiksearch": {
      "command": "bunx",
      "args": [
        "--registry=http://bnpm.byted.org/",
        "@tiktok-mcp/tiksearch"
      ],
      "env": {
        "NPM_CONFIG_REGISTRY": "http://bnpm.byted.org/",
        "TIKSEARCH_ENV": "office"
      }
    }
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "semi-mcp",
    "playwright",
    "lark-docs",
    "tiksearch",
    "feishu"
  ]
}
